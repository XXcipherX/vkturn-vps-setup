# Copy values from this example into command-line options or environment
# variables before running install.sh on a VPS.

WDTT_PASSWORD=change-me-long-random-password
WDTT_VK_LINK=https://vk.com/call/join/your_vk_call_hash
WDTT_PUBLIC_HOST=203.0.113.10

# Defaults are usually fine.
WDTT_DTLS_PORT=56000
WDTT_WG_PORT=56001
WDTT_SSH_PORT=22
WDTT_DNS=1.1.1.1,1.0.0.1

# Optional Telegram access manager.
WDTT_ADMIN_ID=
WDTT_BOT_TOKEN=

# Source used to build wdtt-server.
WDTT_SOURCE_REPO=https://github.com/amurcanov/proxy-turn-vk-android.git
WDTT_SOURCE_REF=main
